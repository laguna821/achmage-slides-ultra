{
  "name": "achmage-slides-ultra",
  "version": "1.0.1",
  "description": "Obsidian plugin: auto-render markdown as slides using Marp engine",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "build:ship": "node esbuild.config.mjs production && node scripts/build-ship.mjs",
    "typecheck": "tsc --noEmit",
    "generate:tier3-bg": "node scripts/generate-tier3-backgrounds.mjs",
    "acceptance:native-1920-v5": "node scripts/render-native-1920-v5-acceptance.mjs",
    "acceptance:overflow": "node scripts/render-overflow-matrix.mjs",
    "acceptance:all": "npm run typecheck && npm run build && npm run acceptance:overflow"
  },
  "keywords": [
    "obsidian",
    "slides",
    "marp",
    "presentation",
    "markdown"
  ],
  "license": "MIT",
  "dependencies": {
    "@marp-team/marp-core": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.6.0"
  }
}
